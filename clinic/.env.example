# Environment Variables Example

# This file shows the required environment variables for the application
# Copy this file to .env and fill in your actual values

# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Clinic Router IP for Turbo Sync (OPTIONAL)
# Set this to your clinic's router IP to enable fast sync when on clinic WiFi
VITE_CLINIC_ROUTER_IP=192.168.3.1

# Security Passwords
VITE_STATS_PASSWORD=0005
VITE_EXPENSES_PASSWORD=1995

# AI Services (OPTIONAL - for AI-powered features)
# Gemini API Key from https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Grok API Key from https://console.x.ai/
VITE_GROK_API_KEY=your_grok_api_key_here
