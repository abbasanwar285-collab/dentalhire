@echo off
chcp 65001
cls
echo ===================================================
echo      تثبيت برنامج مزامنة الأشعة - العيادة الذكية
echo ===================================================
echo.
echo جاري التحقق من وجود الأدوات اللازمة...
echo.

where node >nul 2>nul
if %errorlevel% neq 0 (
    echo [خطأ] برنامج Node.js غير مثبت!
    echo يرجى تحميله وتثبيته من الموقع الرسمي: https://nodejs.org/
    echo.
    echo بعد التثبيت، يرجى تشغيل هذا الملف مرة أخرى.
    pause
    exit
)

echo [موافق] تم العثور على Node.js
echo.
echo جاري تثبيت المكتبات البرمجية المطلوبة...
echo يرجى الانتظار قليلاً (قد يستغرق دقيقة)...
echo.

call npm install

if %errorlevel% neq 0 (
    echo.
    echo [خطأ] حدثت مشكلة أثناء التثبيت.
    echo تأكد من اتصالك بالإنترنت وحاول مرة أخرى.
    pause
    exit
)

echo.
echo ===================================================
echo           تم التثبيت بنجاح!
echo ===================================================
echo.
echo يمكنك الآن إغلاق هذه النافذة وتشغيل ملف "2-تشغيل_المزامنة.bat"
echo.
pause
